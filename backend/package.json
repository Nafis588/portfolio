{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Express backend for MERN portfolio",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --ignore \"data/*\" --ignore \"messages.json\" --ignore \"*.json\" --exec \"node --loader ts-node/esm\" server.ts",
    "seed": "node --loader ts-node/esm seed.ts"
  },
  "dependencies": {
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.3.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^8.0.1",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
